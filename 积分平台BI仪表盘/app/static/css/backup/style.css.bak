/* ============================================
   积分兑换平台 BI 驾驶舱 v4
   深蓝赛博立体风格（智慧能源大屏风）
   ============================================ */

:root {
  --bg: #040b1c;
  --bg-deep: #02060f;
  --bg-card: rgba(8, 24, 56, 0.55);
  --bg-card-2: rgba(4, 16, 40, 0.7);
  --line: rgba(0, 217, 255, 0.35);
  --line-soft: rgba(0, 217, 255, 0.12);
  --cyan: #00e6ff;
  --cyan-soft: rgba(0, 230, 255, 0.4);
  --cyan-faint: rgba(0, 230, 255, 0.08);
  --blue: #00d9ff;
  --blue-deep: #0066ff;
  --purple: #7862ff;
  --blue-text: #94c8ff;
  --blue-text-2: #5a8bd6;
  --blue-text-3: #3d6299;
  --red: #ff3e6c;
  --green: #00ff9d;
  --orange: #ffae00;
}

* { box-sizing: border-box; margin: 0; padding: 0; }
html, body {
  background: var(--bg);
  color: #d6e8ff;
  font-family: 'Inter', 'Noto Sans SC', system-ui, sans-serif;
  font-size: 14px;
  min-height: 100vh;
  width: 100%;
  overflow-x: hidden;
  position: relative;
}

/* 星云底图 */
body::before {
  content: '';
  position: fixed; inset: 0; z-index: 0; pointer-events: none;
  background:
    radial-gradient(ellipse 1200px 600px at 15% 10%, rgba(0,102,255,0.18), transparent 50%),
    radial-gradient(ellipse 1000px 500px at 85% 90%, rgba(120,98,255,0.15), transparent 50%),
    radial-gradient(ellipse 800px 400px at 50% 50%, rgba(0,217,255,0.06), transparent 60%),
    linear-gradient(rgba(0,217,255,0.03) 1px, transparent 1px) 0 0 / 60px 60px,
    linear-gradient(90deg, rgba(0,217,255,0.03) 1px, transparent 1px) 0 0 / 60px 60px,
    var(--bg-deep);
}
body::after {
  content: '';
  position: fixed; inset: 0; z-index: 1; pointer-events: none; opacity: 0.08;
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9'/></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>");
}

/* ===== 顶部通栏 ===== */
.topbar {
  position: relative; z-index: 10;
  height: 72px;
  display: grid; grid-template-columns: 320px 1fr 360px;
  align-items: center;
  padding: 0 28px;
  background: linear-gradient(180deg, rgba(8, 24, 56, 0.85), rgba(4, 16, 40, 0.4));
  border-bottom: 1px solid var(--line);
  backdrop-filter: blur(8px);
  box-shadow: 0 4px 24px rgba(0, 217, 255, 0.08);
}
.topbar::after {
  content: '';
  position: absolute; bottom: 0; left: 5%; right: 5%; height: 1px;
  background: linear-gradient(90deg, transparent, var(--cyan) 50%, transparent);
  opacity: 0.6;
}
.topbar-l { display: flex; align-items: center; gap: 14px; }
.clock {
  display: flex; flex-direction: column; gap: 2px;
  font-family: 'JetBrains Mono', monospace;
}
.clock .date { font-size: 12px; color: var(--blue-text); letter-spacing: 0.1em; }
.clock .time { font-size: 18px; font-weight: 600; color: #d6e8ff; letter-spacing: 0.05em; }

.topbar-c { text-align: center; }
.title {
  font-size: 30px; font-weight: 700;
  background: linear-gradient(180deg, #ffffff 0%, var(--cyan) 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  letter-spacing: 0.18em;
  text-shadow: 0 0 24px rgba(0, 230, 255, 0.4);
  font-family: 'Noto Sans SC', sans-serif;
}
.title-en {
  font-size: 10px; color: var(--blue-text);
  letter-spacing: 0.5em;
  margin-top: 4px;
  font-family: 'Manrope', monospace;
  font-weight: 500;
}

.topbar-r { display: flex; align-items: center; gap: 10px; justify-content: flex-end; }
.icon-btn {
  width: 36px; height: 36px;
  display: grid; place-items: center;
  background: linear-gradient(180deg, rgba(0,217,255,0.1), rgba(0,217,255,0.02));
  border: 1px solid var(--line-soft);
  border-radius: 4px;
  color: var(--blue-text);
  cursor: pointer;
  position: relative;
  transition: all 0.2s;
}
.icon-btn:hover { color: var(--cyan); border-color: var(--cyan-soft); box-shadow: 0 0 12px var(--cyan-faint); }
.icon-btn .badge {
  position: absolute; top: -3px; right: -3px;
  min-width: 16px; height: 16px;
  background: var(--red);
  border-radius: 8px;
  font-size: 10px; color: #fff;
  display: grid; place-items: center;
  padding: 0 4px;
  font-weight: 700;
}
.icon-btn svg { width: 16px; height: 16px; }

/* ===== Main ===== */
.main {
  position: relative; z-index: 5;
  padding: 16px 20px 80px;
  display: flex; flex-direction: column; gap: 14px;
  height: calc(100vh - 72px - 56px);
  min-height: 700px;
}

/* ===== 6 块 KPI 六边形发光指标框 ===== */
.row.kpi-row {
  display: grid; grid-template-columns: repeat(6, 1fr);
  gap: 14px;
}
.kpi {
  position: relative;
  height: 100px;
  padding: 14px 18px;
  background: linear-gradient(180deg, rgba(0, 217, 255, 0.08) 0%, rgba(8, 24, 56, 0.5) 100%);
  border: 1px solid var(--cyan-soft);
  border-radius: 4px;
  display: flex; flex-direction: column; justify-content: space-between;
  overflow: hidden;
  box-shadow:
    inset 0 0 16px rgba(0, 217, 255, 0.06),
    0 0 12px rgba(0, 217, 255, 0.08);
}
/* 四角装饰 */
.kpi::before, .kpi::after {
  content: ''; position: absolute;
  width: 10px; height: 10px;
  border: 1px solid var(--cyan);
  pointer-events: none;
}
.kpi::before { top: -1px; left: -1px; border-right: none; border-bottom: none; }
.kpi::after { bottom: -1px; right: -1px; border-left: none; border-top: none; }
.kpi .corner-tr, .kpi .corner-bl {
  position: absolute; width: 10px; height: 10px;
  border: 1px solid var(--cyan);
  pointer-events: none;
}
.kpi .corner-tr { top: -1px; right: -1px; border-left: none; border-bottom: none; }
.kpi .corner-bl { bottom: -1px; left: -1px; border-right: none; border-top: none; }

.kpi-tag {
  font-size: 11px; font-weight: 500;
  letter-spacing: 0.2em;
  color: var(--blue-text);
  font-family: 'Manrope', monospace;
  text-transform: uppercase;
}
.kpi-val {
  font-family: 'Manrope', 'Noto Sans SC', sans-serif;
  font-size: 32px; font-weight: 800;
  color: var(--cyan);
  line-height: 1.1;
  letter-spacing: -0.01em;
  text-shadow: 0 0 12px rgba(0, 230, 255, 0.5);
}
.kpi-sub {
  font-size: 11px;
  color: var(--blue-text-2);
  display: flex; align-items: center; justify-content: space-between;
}
.kpi-sub .arrow { color: var(--cyan); }

/* ===== Panel 通用 ===== */
.panel {
  position: relative;
  background: linear-gradient(180deg, rgba(8, 24, 56, 0.55) 0%, rgba(4, 16, 40, 0.75) 100%);
  border: 1px solid var(--line);
  border-radius: 4px;
  display: flex; flex-direction: column;
  overflow: hidden;
  backdrop-filter: blur(4px);
  box-shadow:
    inset 0 0 24px rgba(0, 217, 255, 0.04),
    0 0 16px rgba(0, 217, 255, 0.06);
}
/* 四角装饰 */
.panel::before, .panel::after {
  content: ''; position: absolute;
  width: 14px; height: 14px;
  border: 2px solid var(--cyan);
  pointer-events: none;
  z-index: 2;
}
.panel::before { top: -1px; left: -1px; border-right: none; border-bottom: none; }
.panel::after { bottom: -1px; right: -1px; border-left: none; border-top: none; }
.panel .pc-tr, .panel .pc-bl {
  position: absolute; width: 14px; height: 14px;
  border: 2px solid var(--cyan);
  pointer-events: none;
  z-index: 2;
}
.panel .pc-tr { top: -1px; right: -1px; border-left: none; border-bottom: none; }
.panel .pc-bl { bottom: -1px; left: -1px; border-right: none; border-top: none; }

.panel-hd {
  display: flex; align-items: center; justify-content: space-between;
  padding: 12px 18px 8px;
  flex-shrink: 0;
  border-bottom: 1px solid var(--line-soft);
  position: relative;
}
.panel-hd::before {
  content: ''; position: absolute; left: 18px; right: 18px; bottom: -1px; height: 1px;
  background: linear-gradient(90deg, transparent, var(--cyan-soft) 50%, transparent);
}
.hd-l { display: flex; align-items: center; gap: 10px; }
.hd-num {
  font-family: 'Manrope', monospace;
  font-size: 18px; font-weight: 800;
  color: var(--cyan);
  text-shadow: 0 0 8px var(--cyan-faint);
}
.hd-title {
  font-size: 15px; font-weight: 600;
  color: #c4e2ff;
  letter-spacing: 0.06em;
  font-family: 'Noto Sans SC', sans-serif;
}
.hd-sub {
  font-size: 9px; font-weight: 500;
  letter-spacing: 0.25em;
  color: var(--blue-text-3);
  font-family: 'Manrope', monospace;
}
.hd-r { display: flex; align-items: center; gap: 6px; font-size: 10px; color: var(--blue-text); }
.pulse-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--cyan);
  box-shadow: 0 0 8px var(--cyan);
  animation: pulse 1.5s ease-in-out infinite;
}
@keyframes pulse { 0%,100% { opacity: 1 } 50% { opacity: 0.4 } }
.panel-bd { flex: 1; padding: 4px 8px 8px; min-height: 0; position: relative; overflow: hidden; }

/* ===== 地图侧边栏 ===== */
.row.r2 { display: grid; grid-template-columns: 1.4fr 1.4fr 1fr; gap: 14px; flex: 1.3; min-height: 0; }
.row.r3 { display: grid; grid-template-columns: 1.4fr 1.1fr 0.9fr 1.1fr; gap: 14px; flex: 1.1; min-height: 0; }

.p-map { display: flex; }
.p-map .panel-bd { display: flex; }
.map-wrap { position: relative; flex: 1; display: flex; min-width: 0; }
.map-side {
  width: 110px; flex-shrink: 0;
  display: flex; flex-direction: column; gap: 6px;
  padding: 8px 0 8px 0;
}
.map-side .side-item {
  padding: 8px 10px;
  font-size: 11px; color: var(--blue-text);
  background: rgba(0, 217, 255, 0.04);
  border: 1px solid var(--line-soft);
  border-radius: 2px;
  cursor: pointer;
  letter-spacing: 0.05em;
  transition: all 0.2s;
  text-align: center;
}
.map-side .side-item:hover, .map-side .side-item.active {
  color: var(--cyan);
  background: rgba(0, 217, 255, 0.12);
  border-color: var(--cyan-soft);
  box-shadow: 0 0 8px var(--cyan-faint);
}
.map-side .side-label {
  font-size: 10px; color: var(--blue-text-3);
  text-align: center;
  letter-spacing: 0.15em;
  margin-bottom: 4px;
  font-family: 'Manrope', monospace;
}
#chart-map { flex: 1; }

/* ===== 实时订单流 ===== */
#chart-trend, #chart-pie, #chart-combo, #chart-merch, #chart-gauge {
  width: 100%;
  height: 100%;
}
#recent-list { padding: 4px 0; overflow-y: auto; height: 100%; }
.recent-row {
  display: grid;
  grid-template-columns: 64px 1fr 70px 64px;
  align-items: center;
  padding: 8px 14px;
  border-bottom: 1px solid var(--line-soft);
  font-size: 11px;
  transition: background 0.2s;
  position: relative;
}
.recent-row:hover { background: rgba(0, 217, 255, 0.06); }
.recent-time {
  font-family: 'JetBrains Mono', monospace;
  color: var(--blue-text-2);
  font-size: 10px;
}
.recent-name {
  color: #d6e8ff;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.recent-name .gift { color: var(--blue-text-3); font-size: 10px; margin-left: 4px; }
.recent-coin {
  font-family: 'Manrope', monospace;
  font-size: 14px; font-weight: 700;
  color: var(--cyan);
  text-align: right;
  text-shadow: 0 0 6px var(--cyan-faint);
}
.recent-status {
  font-size: 9px; font-weight: 600;
  padding: 2px 6px;
  border-radius: 2px;
  text-align: center;
  letter-spacing: 0.1em;
  border: 1px solid;
}
.status-1 { color: var(--blue-text); background: rgba(0, 217, 255, 0.08); border-color: var(--cyan-soft); }
.status-2 { color: var(--orange); background: rgba(255, 174, 0, 0.08); border-color: rgba(255, 174, 0, 0.4); }
.status-3 { color: var(--green); background: rgba(0, 255, 157, 0.08); border-color: rgba(0, 255, 157, 0.4); }
.status-4 { color: var(--red); background: rgba(255, 62, 108, 0.08); border-color: rgba(255, 62, 108, 0.4); animation: blink 1.2s ease-in-out infinite; }
@keyframes blink { 0%,100% { opacity: 1 } 50% { opacity: 0.5 } }

/* ===== 底部导航栏 ===== */
.footer-nav {
  position: fixed; left: 0; right: 0; bottom: 0; z-index: 100;
  height: 56px;
  background: linear-gradient(180deg, rgba(8, 24, 56, 0.7) 0%, rgba(4, 16, 40, 0.95) 100%);
  border-top: 1px solid var(--line);
  display: flex; align-items: center; justify-content: center;
  gap: 4px;
  padding: 0 16px;
  backdrop-filter: blur(10px);
  box-shadow: 0 -4px 24px rgba(0, 217, 255, 0.1);
}
.footer-nav::before {
  content: ''; position: absolute; top: 0; left: 5%; right: 5%; height: 1px;
  background: linear-gradient(90deg, transparent, var(--cyan) 50%, transparent);
  opacity: 0.6;
}
.nav-item {
  padding: 8px 18px;
  font-size: 13px; font-weight: 500;
  color: var(--blue-text);
  cursor: pointer;
  letter-spacing: 0.1em;
  border-radius: 2px;
  position: relative;
  transition: all 0.2s;
  font-family: 'Noto Sans SC', sans-serif;
}
.nav-item::before {
  content: ''; position: absolute; left: 50%; top: -8px; transform: translateX(-50%);
  width: 0; height: 2px;
  background: var(--cyan);
  box-shadow: 0 0 8px var(--cyan);
  transition: width 0.2s;
}
.nav-item:hover { color: var(--cyan); }
.nav-item:hover::before, .nav-item.active::before { width: 60%; }
.nav-item.active {
  color: var(--cyan);
  background: rgba(0, 217, 255, 0.08);
  border: 1px solid var(--cyan-soft);
}

/* 滚动条 */
::-webkit-scrollbar { width: 4px; height: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--cyan-soft); border-radius: 2px; }
::-webkit-scrollbar-thumb:hover { background: var(--cyan); }

@media (max-width: 1500px) {
  .row.kpi-row { grid-template-columns: repeat(3, 1fr); }
  .kpi-val { font-size: 26px; }
  .row.r2, .row.r3 { grid-template-columns: 1fr 1fr; }
  .map-side { display: none; }
}
